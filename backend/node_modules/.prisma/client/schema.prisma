generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  domain    String?
  logo      String?
  coupons   Coupon[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id      Int              @id @default(autoincrement())
  name    String
  slug    String           @unique
  icon    String?
  coupons CouponCategory[]
}

model Coupon {
  id          Int       @id @default(autoincrement())
  title       String
  code        String?
  type        String    @default("code")
  discount    String?
  description String?
  expiryDate  DateTime?

  merchantId Int
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  sourceUrl   String
  source      String
  fingerprint String @unique

  // SmallInt: only 1/2/3 — saves 2 bytes per row, no ALTER needed on existing INT data
  priority Int @default(3) @db.SmallInt

  clicks     Int      @default(0)
  isActive   Boolean  @default(true)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categories CouponCategory[]

  // Replaces the old [isActive, createdAt] index — matches actual ORDER BY
  @@index([isActive, priority, isVerified, clicks])
  @@index([merchantId, isActive])
  @@index([source, isActive])
}

model CouponCategory {
  couponId   Int
  categoryId Int
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([couponId, categoryId])
  @@index([categoryId])
}

model ScrapeJob {
  id           Int       @id @default(autoincrement())
  source       String
  targetUrl    String
  status       String    @default("pending")
  couponsFound Int       @default(0)
  newCoupons   Int       @default(0)
  error        String?
  triggeredBy  String    @default("scheduler")
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
