generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Merchant ────────────────────────────────────────────────────────────────
model Merchant {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(120)
  domain    String?  @db.VarChar(120)
  logo      String?  @db.VarChar(300)
  coupons   Coupon[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Category ────────────────────────────────────────────────────────────────
model Category {
  id      Int              @id @default(autoincrement())
  name    String           @db.VarChar(60)
  slug    String           @unique @db.VarChar(60)
  icon    String?          @db.VarChar(60)
  coupons CouponCategory[]
}

// ─── Coupon ──────────────────────────────────────────────────────────────────
model Coupon {
  id          Int       @id @default(autoincrement())

  // User-facing text — left as TEXT (no VarChar) since scraped content varies widely
  title       String
  description String?

  // Short bounded fields — VarChar avoids TOAST for these
  code        String?  @db.VarChar(30)            // real codes are ≤ 20 chars
  type        String   @default("code") @db.VarChar(10) // 'code' | 'deal' | 'cashback'
  discount    String?  @db.VarChar(80)            // "Flat ₹500 off", "20% off"

  expiryDate  DateTime?

  merchantId  Int
  merchant    Merchant  @relation(fields: [merchantId], references: [id])

  // sourceUrl left as TEXT — some sites have very long query-string URLs
  sourceUrl   String
  source      String   @db.VarChar(30)            // 'coupondunia' | 'grabon' | 'direct' …
  fingerprint String   @unique @db.Char(64)       // SHA-256 hex = exactly 64 chars

  // SmallInt: only ever 1, 2, or 3 — saves 2 bytes per row vs Int
  priority    Int      @default(3) @db.SmallInt   // 1=direct code, 2=bank code, 3=deal

  clicks      Int      @default(0)
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  CouponCategory[]

  // Covers: WHERE isActive=true ORDER BY priority, isVerified DESC, clicks DESC
  @@index([isActive, priority, isVerified, clicks])
  // Covers: WHERE merchantId=? AND isActive=true
  @@index([merchantId, isActive])
  // Covers: WHERE source=? AND isActive=true
  @@index([source, isActive])
}

// ─── CouponCategory ──────────────────────────────────────────────────────────
model CouponCategory {
  couponId   Int
  categoryId Int
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([couponId, categoryId])
  @@index([categoryId])
}

// ─── ScrapeJob ───────────────────────────────────────────────────────────────
model ScrapeJob {
  id           Int       @id @default(autoincrement())
  source       String    @db.VarChar(30)
  targetUrl    String                               // can be long, leave as TEXT
  status       String    @default("pending") @db.VarChar(10)
  couponsFound Int       @default(0)
  newCoupons   Int       @default(0)
  error        String?                              // stack traces can be long
  triggeredBy  String    @default("scheduler") @db.VarChar(20)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([source, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
