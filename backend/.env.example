DATABASE_URL="postgresql://postgres:password@localhost:5432/couponsite"
REDIS_URL="redis://localhost:6379"
PORT=4000
NODE_ENV=development

# Admin API key for triggering scrapes
ADMIN_API_KEY=change-me-in-production

# Optional: rotating proxies for scraping (comma-separated)
PROXY_LIST=

# Scrape schedule (cron syntax) - default: every 6 hours
SCRAPE_CRON="0 */6 * * *"
